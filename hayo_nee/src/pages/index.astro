---
// src/pages/index.astro
// トップページです。
// ヒーローセクション・キャラクター横スクロールリスト・
// 小説一覧・Aboutリンクを表示します。

import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// キャラクターと小説のデータを取得します
const characters = await getCollection('characters');
const novels = await getCollection('novels');

// 小説を公開日の新しい順に並べ替えます
const sortedNovels = novels.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

// chapterごとにグループ化（同じタイトルの作品をまとめる）
const novelGroups = sortedNovels.reduce((acc, novel) => {
  const series = novel.data.series || novel.data.title;
  if (!acc[series]) acc[series] = [];
  acc[series].push(novel);
  return acc;
}, {} as Record<string, typeof novels>);
---

<BaseLayout title="hayo_nee" description="自作キャラクターと小説の紹介サイト">

  <!-- ===============================
       ヒーローセクション
       サイト名とキャッチコピーを表示します
  ================================ -->
  <section
    class="section pt-20 pb-16 text-center"
    x-data
    x-init="$el.classList.add('animate-bounce-in')"
  >
    <div class="container-main">

      <!-- サイトアイコン（SVGプレースホルダー） -->
      <div class="mx-auto mb-8 w-20 h-20 rounded-full bg-[#dce8f0] flex items-center justify-center animate-bounce-in">
        <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" class="w-12 h-12">
          <!-- 星のアイコン（サイトのイメージ） -->
          <circle cx="40" cy="40" r="38" fill="none" stroke="#6090b0" stroke-width="1"/>
          <path d="M40 16 L43 33 L60 33 L47 43 L52 60 L40 50 L28 60 L33 43 L20 33 L37 33 Z"
                fill="#6090b0" opacity="0.7"/>
          <circle cx="40" cy="40" r="5" fill="#6090b0"/>
        </svg>
      </div>

      <!-- サイト名 -->
      <h1 class="font-display text-4xl md:text-5xl font-light tracking-[0.2em] text-[#3d3a36] mb-4 animate-fade-up delay-100">
        hayo_nee
      </h1>

      <!-- キャッチコピー -->
      <p class="text-[#8a8278] font-light text-sm tracking-widest mb-2 animate-fade-up delay-200">
        自作キャラクターと小説の世界へ
      </p>
      <p class="text-[#8a8278] font-light text-xs tracking-wide animate-fade-up delay-300">
        — characters &amp; original stories —
      </p>

    </div>
  </section>

  <!-- ===============================
       区切り線
  ================================ -->
  <div class="container-main">
    <hr />
  </div>

  <!-- ===============================
       キャラクター一覧（横スクロール）
       サイト上部に横スクロールリストで表示します
  ================================ -->
  <section class="section">
    <div class="container-main">

      <!-- セクションヘッダー -->
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="font-display text-xl font-light tracking-wider text-[#3d3a36]">
          キャラクター
          <span class="text-[#8a8278] text-sm ml-2">characters</span>
        </h2>
        <a href="/characters" class="text-xs text-[#6090b0] font-light hover:opacity-70 transition-opacity">
          一覧を見る →
        </a>
      </div>

      <!-- 横スクロールコンテナ -->
      <div class="scroll-x-container pb-4" role="list">
        {characters.map((chara, i) => (
          <a
            href={`/characters/${chara.slug}`}
            class="flex-none w-36 text-center group animate-bounce-in"
            style={`animation-delay: ${i * 100}ms`}
            role="listitem"
          >
            <!-- キャラクターアイコン -->
            <div
              class="w-24 h-24 mx-auto rounded-full mb-3 flex items-center justify-center text-[#faf8f5] font-display text-2xl transition-transform duration-300 group-hover:scale-110"
              style={`background-color: ${chara.data.color || '#b8cfe0'}`}
            >
              {chara.data.nameEn.charAt(0).toUpperCase()}
            </div>
            <!-- キャラクター名 -->
            <p class="text-xs font-light text-[#3d3a36] leading-tight mb-0.5">
              {chara.data.name}
            </p>
            <p class="text-[10px] text-[#8a8278] font-light tracking-wider">
              {chara.data.nameEn}
            </p>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ===============================
       小説一覧（縦リスト）
  ================================ -->
  <section class="section bg-[#f3efe8]">
    <div class="container-main">

      <!-- セクションヘッダー -->
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="font-display text-xl font-light tracking-wider text-[#3d3a36]">
          小説
          <span class="text-[#8a8278] text-sm ml-2">novels</span>
        </h2>
        <a href="/novels" class="text-xs text-[#6090b0] font-light hover:opacity-70 transition-opacity">
          一覧を見る →
        </a>
      </div>

      <!-- 小説カードリスト -->
      <div class="flex flex-col gap-4">
        {Object.entries(novelGroups).map(([seriesTitle, chapters], i) => {
          // 各シリーズの最新章を取得
          const latestChapter = chapters[0];
          const totalChapters = chapters.length;
          return (
            <article
              class="card group animate-bounce-in"
              style={`animation-delay: ${i * 150}ms`}
            >
              <a href={`/novels/${latestChapter.slug}`} class="block no-underline">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <!-- シリーズタイトル -->
                    <h3 class="font-display text-lg font-light text-[#3d3a36] mb-1 group-hover:text-[#6090b0] transition-colors">
                      {seriesTitle}
                    </h3>
                    <!-- あらすじ -->
                    <p class="text-sm text-[#8a8278] font-light line-clamp-2 mb-3">
                      {latestChapter.data.summary}
                    </p>
                    <!-- メタ情報（タグ・章数） -->
                    <div class="flex flex-wrap items-center gap-2">
                      {latestChapter.data.tags?.map(tag => (
                        <span class="badge">{tag}</span>
                      ))}
                      <span class="text-xs text-[#8a8278] font-light ml-auto">
                        全{totalChapters}話
                      </span>
                    </div>
                  </div>
                  <!-- 矢印アイコン -->
                  <div class="flex-none text-[#b8cfe0] group-hover:text-[#6090b0] transition-colors mt-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
                    </svg>
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>

    </div>
  </section>

  <!-- ===============================
       Aboutへのリンク（サイト下部）
  ================================ -->
  <section class="section text-center">
    <div class="container-main">

      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <!-- Aboutページへのリンク -->
        <a href="/about" class="btn-ghost animate-bounce-in delay-100">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          作者について
        </a>
        <!-- SNSリンク（プレースホルダー） -->
        <a href="https://x.com/" target="_blank" rel="noopener noreferrer" class="btn-ghost animate-bounce-in delay-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          X (Twitter)
        </a>
      </div>

    </div>
  </section>

</BaseLayout>
