---
// src/pages/novels/index.astro
// 小説一覧ページです。
// 作品タイトル・あらすじ・更新日をリスト形式で表示します。
// Alpine.jsを使って検索とフィルタリングができます。

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// すべての小説データを取得して公開日順に並べます
const novels = await getCollection('novels');
const sorted = novels.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

// すべてのタグを収集してフィルター用に準備します
const allTags = [...new Set(sorted.flatMap(n => n.data.tags || []))];

// キャラクターデータも取得してバッジ表示に使います
const characters = await getCollection('characters');

// Alpine.jsのためにデータをJSON化します（クライアントサイドで使用）
const novelsJson = JSON.stringify(sorted.map(n => ({
  slug: n.slug,
  title: n.data.title,
  chapter: n.data.chapter,
  summary: n.data.summary,
  series: n.data.series || n.data.title,
  tags: n.data.tags || [],
  characters: n.data.characters || [],
  publishedAt: n.data.publishedAt.toISOString().split('T')[0],
  updatedAt: n.data.updatedAt?.toISOString().split('T')[0],
})));

const charsJson = JSON.stringify(characters.map(c => ({
  slug: c.slug,
  name: c.data.name,
  color: c.data.color || '#b8cfe0',
})));
---

<BaseLayout
  title="小説一覧"
  description="自作小説の一覧ページです。"
>

  <div class="container-main section">

    <!-- ページヘッダー -->
    <div class="mb-10 animate-fade-up">
      <p class="text-xs text-[#8a8278] tracking-widest mb-2">— novels —</p>
      <h1 class="font-display text-3xl font-light text-[#3d3a36] tracking-wide">
        小説一覧
      </h1>
    </div>

    <!-- ===============================
         Alpine.jsで検索・フィルター機能を実装します
         x-data でコンポーネントのデータと関数を定義します
    ================================ -->
    <div
      x-data={`{
        novels: ${novelsJson},
        chars: ${charsJson},
        query: '',
        activeTag: '',
        get filtered() {
          return this.novels.filter(n => {
            const matchQuery = !this.query ||
              n.title.includes(this.query) ||
              n.summary.includes(this.query);
            const matchTag = !this.activeTag ||
              n.tags.includes(this.activeTag);
            return matchQuery && matchTag;
          });
        },
        getChar(slug) {
          return this.chars.find(c => c.slug === slug);
        }
      }`}
    >

      <!-- 検索バー -->
      <div class="relative mb-6 animate-fade-up delay-100">
        <input
          type="search"
          x-model="query"
          placeholder="作品名・あらすじで検索..."
          class="w-full bg-[#f3efe8] border border-[#e8e0d4] rounded-2xl px-4 py-3 pl-10 text-sm font-light text-[#3d3a36] placeholder-[#8a8278] focus:outline-none focus:border-[#6090b0] transition-colors"
        />
        <!-- 検索アイコン -->
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[#8a8278]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </div>

      <!-- タグフィルター -->
      <div class="flex flex-wrap gap-2 mb-8 animate-fade-up delay-200">
        <!-- 「すべて」ボタン -->
        <button
          @click="activeTag = ''"
          :class="activeTag === '' ? 'bg-[#6090b0] text-[#faf8f5]' : 'bg-[#f3efe8] text-[#8a8278] hover:bg-[#dce8f0]'"
          class="px-3 py-1 rounded-full text-xs font-light transition-colors"
        >
          すべて
        </button>
        <!-- 各タグボタン -->
        {allTags.map(tag => (
          <button
            @click={`activeTag = activeTag === '${tag}' ? '' : '${tag}'`}
            :class={`activeTag === '${tag}' ? 'bg-[#6090b0] text-[#faf8f5]' : 'bg-[#f3efe8] text-[#8a8278] hover:bg-[#dce8f0]'`}
            class="px-3 py-1 rounded-full text-xs font-light transition-colors"
          >
            {tag}
          </button>
        ))}
      </div>

      <!-- 小説リスト -->
      <div class="flex flex-col gap-4">

        <!-- 検索結果なしのメッセージ -->
        <p
          x-show="filtered.length === 0"
          class="text-center text-[#8a8278] font-light py-12"
          style="display: none;"
        >
          条件に合う作品が見つかりませんでした。
        </p>

        <!-- 小説カードをループ表示 -->
        <template x-for="novel in filtered" :key="novel.slug">
          <article class="card animate-bounce-in">
            <a :href="`/novels/${novel.slug}`" class="block no-underline group">

              <div class="flex items-start gap-4">
                <!-- チャプター番号 -->
                <div class="flex-none w-10 h-10 rounded-full bg-[#dce8f0] flex items-center justify-center text-xs text-[#6090b0] font-light mt-0.5">
                  <span x-text="`${novel.chapter}`"></span>
                </div>

                <div class="flex-1 min-w-0">
                  <!-- タイトル -->
                  <div class="flex items-baseline gap-2 mb-1">
                    <h2
                      class="font-display text-base font-light text-[#3d3a36] group-hover:text-[#6090b0] transition-colors"
                      x-text="novel.series"
                    ></h2>
                    <span class="text-xs text-[#8a8278] font-light" x-text="`第${novel.chapter}話`"></span>
                  </div>

                  <!-- あらすじ -->
                  <p
                    class="text-sm text-[#8a8278] font-light line-clamp-2 mb-3"
                    x-text="novel.summary"
                  ></p>

                  <!-- 登場人物バッジ＆更新日 -->
                  <div class="flex flex-wrap items-center gap-2">
                    <!-- 登場人物の苗字バッジ -->
                    <template x-for="charSlug in novel.characters" :key="charSlug">
                      <span
                        class="inline-block px-2 py-0.5 rounded-full text-[10px] text-[#faf8f5] font-light"
                        :style="`background-color: ${getChar(charSlug)?.color || '#b8cfe0'}`"
                        x-text="getChar(charSlug)?.name?.split(' ')[0] || charSlug"
                      ></span>
                    </template>
                    <!-- 更新日 -->
                    <span class="text-[10px] text-[#8a8278] font-light ml-auto" x-text="novel.updatedAt || novel.publishedAt"></span>
                  </div>

                </div>

                <!-- 矢印 -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#b8cfe0] group-hover:text-[#6090b0] transition-colors flex-none mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
                </svg>
              </div>

            </a>
          </article>
        </template>

      </div>

    </div>

  </div>

</BaseLayout>
